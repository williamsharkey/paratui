# Auth focus should be keyboard-drivable before login.
!assert focus=auth
!assert actions.selectedId=open_api_help
!press down
!wait actions.selectedId=paste_api_key
!press space
!wait auth.inputActive=true
!press escape
!wait auth.inputActive=false
!wait focus=auth

# Hidden test commands should still be scriptable.
/auth/login
!wait auth.inputActive=true
!press escape
!wait auth.inputActive=false

# Full commands with args should still execute.
/auth/key/set psn_test_sharkgod
!wait auth.loggedIn=true
!wait focus=left

# Tab and shift-tab should walk the active panes.
!press tab
!wait focus=center
!wait actions.selectedId=previous_feed
!press shift-tab
!wait focus=left

# Command execution should still target the live UI state.
/people/profile @crosshj
!wait view=profile
!screen-contains profile @crosshj
