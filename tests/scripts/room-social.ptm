# Open a public room from the left pane and post a message.
/auth/key/set psn_test_sharkgod
/rooms/open mutations
!assert view=room
!assert room.name=mutations
!wait room.messageCount=2
!screen-contains room #mutations
!screen-contains users:
!screen-contains chain two prompts and post it
!type macro room ping
!assert composer.active=true
!press enter
!wait room.messageCount=3
!assert status=room post mutations
!screen-contains macro room ping
!screen-contains + room
/rooms/open noir
!assert view=room
!assert room.name=noir
/rooms/join testroom
!assert view=room
!assert room.name=testroom
!screen-contains room #testroom
