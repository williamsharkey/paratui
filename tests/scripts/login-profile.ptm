# Login and basic people/profile navigation through the live terminal app.
!assert auth.loggedIn=false
!screen-contains Open API Page
/auth/key/open
!assert status=https://www.parascene.com/help/developer/api
!press p
!assert auth.inputActive=true
!press escape
!assert auth.inputActive=false
/auth/key/set psn_test_sharkgod
!assert auth.loggedIn=true
!assert auth.handle=sharkgod
!assert view=feed
!screen-contains @crosshj
!screen-contains @noirguy
!press down
!assert view=notifications
!press up
!assert view=feed
!press down
!press down
!assert view=settings
!press down
!assert selected.handle=sharkgod
!assert profile.handle=sharkgod
!press down
!assert selected.handle=crosshj
!assert view=dm
!assert dm.handle=crosshj
/people/profile @crosshj
!assert profile.handle=crosshj
